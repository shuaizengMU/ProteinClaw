{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProteinClaw",
  "version": "0.1.1",
  "identifier": "com.proteinclaw.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ProteinClaw",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "externalBin": ["binaries/uv"],
    "resources": {
      "../pyproject.toml": "pyproject.toml",
      "../uv.lock": "uv.lock",
      "../proteinclaw": "proteinclaw",
      "../proteinbox": "proteinbox"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
